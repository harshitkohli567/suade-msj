<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!--
    Suade: production manifest for sideloading onto a friend's own Word.
    Points at the deployed Render service, NOT localhost. This is not an
    AppSource submission; Word will still show an "unverified add-in"
    style warning on first load, which is expected for a manually
    sideloaded manifest. See README.md's "Sharing with friends" section
    for exactly how a friend installs this file.

    REPLACE https://suade-msj.onrender.com everywhere below with your
    actual Render service URL once you've deployed (Render shows it on
    the service's dashboard page after the first deploy).
  -->

  <Id>f898416b-61ec-4e30-b945-dea0b8c6234f</Id>
  <Version>0.1.0.0</Version>
  <ProviderName>Suade MSJ</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Suade MSJ" />
  <Description DefaultValue="Contextually-aware, point-of-work AI for arbitration lawyers." />
  <IconUrl DefaultValue="https://suade-msj.onrender.com/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://suade-msj.onrender.com/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://suade-msj.onrender.com" />

  <AppDomains>
    <AppDomain>https://suade-msj.onrender.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WordApi" MinVersion="1.4" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://suade-msj.onrender.com/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="Suade.Group1">
                <Label resid="Group1.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="Suade.TaskpaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>Suade.Taskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://suade-msj.onrender.com/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://suade-msj.onrender.com/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://suade-msj.onrender.com/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://suade-msj.onrender.com/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://suade-msj.onrender.com/taskpane.html" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://suade-msj.onrender.com" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Suade is ready" />
        <bt:String id="Group1.Label" DefaultValue="Suade MSJ" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Suade MSJ" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Suade tracks where you are in the document and surfaces the relevant drafting Skill -- no chatbot prompt required." />
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Suade task pane" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
